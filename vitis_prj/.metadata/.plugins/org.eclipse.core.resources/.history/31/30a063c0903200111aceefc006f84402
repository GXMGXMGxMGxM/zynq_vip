#include "xil_printf.h"
#include "xparameters.h"
#include "xaxivdma.h"
#include "vdma_api.h"
#include "xstatus.h"
#include "xil_cache.h"

#define VDMA_DEVICE_ID          XPAR_AXIVDMA_0_DEVICE_ID
#define DDR_BASEADDR            XPAR_PS7_DDR_0_S_AXI_BASEADDR
#define BUFFER_BASEADDR         (DDR_BASEADDR + 0x1000000) 

#define IMG_WIDTH   1280
#define IMG_HEIGHT  720

int main()
{
    xil_printf("Hello zynq video image process!\r\n");

    //配置并启动VDMA
	XAxiVdma vdma_inst;
    int vdma_status;        
    vdma_status = run_triple_frame_buffer(
            &vdma_inst,                     //VDMA驱动实例
            VDMA_DEVICE_ID,                 //VDMA器件地址
            IMG_WIDTH,                      //传输图像像素宽度 1280
            IMG_HEIGHT,                     //传输图像像素高度 720
            BUFFER_BASEADDR,                //帧缓存基地址
            0, 
            0);
    if (vdma_status != XST_SUCCESS) {
	    xil_printf("VDMA start and config failed with error = %d\r\n",vdma_status);
		return XST_FAILURE;
	} else {
		xil_printf("VDMA start and config successfully \r\n");
	}


    //向DDR中写入图像数据,供VDMA去读
    uint8_t* vdma_buffer_addr = (uint8_t*)BUFFER_BASEADDR;
    int i, j;
    for(j = 0; j < IMG_HEIGHT; j++){
        for(i = 0; i < IMG_WIDTH; i++){
            *(vdma_buffer_addr + IMG_WIDTH*3*j + 3*i    ) = 0x00;   //蓝色通道
            *(vdma_buffer_addr + IMG_WIDTH*3*j + 3*i+1  ) = 0x00;   //绿色通道
            *(vdma_buffer_addr + IMG_WIDTH*3*j + 3*i+2  ) = 0xff;   //红色通道
        }
    }
    //将DataCache中的数据全部冲刷到DDR中
    Xil_DCacheFlush();

    
    xil_printf("Goodbye zynq video image process!\r\n");
    return 0;
}


